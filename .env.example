# --- BACKEND (Firebase Admin) ---
# Você precisará baixar o JSON da conta de serviço no Firebase Console:
# Project Settings > Service Accounts > Generate new private key
FIREBASE_PROJECT_ID=seu-projeto-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@seu-projeto-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# --- FRONTEND (Firebase Client) ---
# Obtenha estes valores em: Project Settings > General > Your apps > Web apps
VITE_FIREBASE_API_KEY=sua-api-key
VITE_FIREBASE_AUTH_DOMAIN=seu-projeto-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=seu-projeto-id
VITE_FIREBASE_STORAGE_BUCKET=seu-projeto-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=seu-sender-id
VITE_FIREBASE_APP_ID=seu-app-id

# --- SEGURANÇA ---
JWT_SECRET=mantido-para-compatibilidade-se-necessario
PORT=5000
